# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google Analytics 4 — Service Account credentials
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored by default in Next.js — never commit the real file.

# The numeric property ID from GA4 (NOT the G-XXXXXXXX measurement ID).
# Find it: GA4 → Admin → Property Settings → "Property ID" (e.g. 123456789)
GA_PROPERTY_ID=

# From your Service Account JSON key file → "client_email"
GA_SERVICE_ACCOUNT_EMAIL=

# From your Service Account JSON key file → "private_key"
# Paste the full value including -----BEGIN PRIVATE KEY----- lines.
# In .env.local, keep it on one line with literal \n characters.
GA_PRIVATE_KEY=
