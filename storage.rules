rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Receipts ─────────────────────────────────────────────────────────────
    // Users can only read and write files in their own receipts folder.
    match /receipts/{uid}/{filename} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }
  }
}
